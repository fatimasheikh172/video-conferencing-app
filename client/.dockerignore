# Docker ignore file for frontend
# Prevents unnecessary files from being copied into Docker image

# IMPORTANT: node_modules is NOT ignored because we copy it from local
# to avoid network issues during Docker build in Pakistan

# Dependencies logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production build (will be created during Docker build)
build/

# Environment files
.env
.env.local
.env.development
.env.production
.env.test

# Testing
coverage/
.nyc_output/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation
*.md
docs/

# Temporary files
tmp/
temp/
*.tmp
