{
  "extends": [
    "react-app",
    "react-app/jest"
  ],
  "rules": {
    "react-hooks/exhaustive-deps": "warn",
    "no-unused-vars": "warn",
    "jsx-a11y/anchor-is-valid": "warn",
    "import/no-anonymous-default-export": "warn",
    "no-useless-escape": "off",
    "no-control-regex": "off",
    "no-script-url": "off"
  }
}
